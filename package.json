{
  "name": "signmate",
  "version": "0.1.20",
  "private": true,
  "description": "SignMate 签伴 - 多站点签到与保活管理",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "start:dev": "node --watch src/index.js",
    "check": "node --check src/server.js && node --check src/runner.js && node --check src/scheduler.js && node --check src/index.js && node --check src/web/app.js",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "test": "npm run check && npm run test:feng && npm run check:browser && npm run audit:prod",
    "test:nodeseek": "node src/drivers/nodeseek.js",
    "check:browser": "node scripts/check-browser.js",
    "release:check": "node scripts/release-check.js",
    "smoke:sites": "node scripts/smoke-sites.js",
    "test:feng": "node scripts/test-feng-credentials.js"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "cloakbrowser": "^0.3.31",
    "crypto-js": "^4.2.0",
    "express": "^4.21.0",
    "iconv-lite": "^0.6.3",
    "node-cron": "^4.2.1",
    "playwright-core": "1.57.0",
    "sharp": "^0.33.0",
    "tesseract.js": "^6.0.0",
    "undici": "8.5.0",
    "yaml": "^2.7.0"
  },
  "displayName": "SignMate",
  "productName": "SignMate 签伴"
}
