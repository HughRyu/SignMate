# ============================================================
# SignMate 签伴 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# --- Telegram 通知（可选） ---
# 发送签到结果到 Telegram
# 获取方式：@BotFather 创建 Bot → @userinfobot 获取 chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- 系统配置 ---
# 时区（默认 Asia/Shanghai）
TZ=Asia/Shanghai

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 启动时是否立即执行一次所有已启用站点的签到
RUN_ON_START=true

# 单次签到 HTTP 超时（毫秒）
HTTP_TIMEOUT=30000
