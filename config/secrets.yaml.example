# ============================================================
# signmate — 凭据配置文件（敏感信息）
# 复制为 secrets.yaml，填入真实凭据
# cp config/secrets.yaml.example config/secrets.yaml
# 并 chmod 600 config/secrets.yaml
# ============================================================

# --- NodeSeek ---
# 登录 NodeSeek 后，从浏览器开发者工具中复制 Cookie
# 找到 session 的值（不含 "session=" 前缀）
nodeseek:
  # 完整 Cookie 字符串（直接用浏览器 F12 → Application → Cookies 复制）
  cookie: "session=<YOUR_SESSION_COOKIE>; colors…n=dark;"

  # 或仅 session 值（如果只用 session 字段签到）
  # session_only: "<YOUR_SESSION_VALUE>"

# --------------------------------------------------
# 新增站点凭据（与 sites.yaml 中的 key 对应）
# --------------------------------------------------
# example_forum:
#   cookie: "..."           # 如果签到用 Cookie
#   # 或 token: "Bearer ..." # 如果签到用 Token
#   # 或 username: "..."
#   #    password: "..."

# --- 百度贴吧 ---
# 登录百度后，从浏览器复制 .baidu.com / tieba.baidu.com 相关 Cookie。
# 通常需要包含 BDUSS / STOKEN 等登录态字段。
baidu-tieba:
  cookie: "BDUSS=<YOUR_BDUSS>; STOKEN=<YOUR_STOKEN>;"

# --- M-Team ---
# 后台“存取令牌”；请求时通过 x-api-key 使用，不是 Cookie。
mteam:
  api_key: <YOUR_MTEAM_ACCESS_TOKEN>
